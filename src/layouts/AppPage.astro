---
import Base from './Base.astro';
import PhoneMockup from '@/components/PhoneMockup.astro';
import type { App } from '@/data/apps';
import { site } from '@/data/site';

interface Props {
  app: App;
}

const { app } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MobileApplication',
  name: app.name,
  operatingSystem: 'Android',
  applicationCategory: app.category,
  description: app.description,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  url: new URL(`/${app.id}/`, site.url).href,
};
---

<Base title={app.name} description={app.metaDescription} jsonLd={jsonLd}>
  <main>
    <!-- HERO -->
    <section
      class="app-hero"
      style={`background: radial-gradient(circle at 75% 40%, ${app.gradientFrom}28 0%, transparent 55%), radial-gradient(circle at 25% 70%, ${app.gradientTo}18 0%, transparent 40%); border-bottom: 1px solid var(--color-border);`}
    >
      <div class="hero-inner">
        <div class="hero-content">
          <span
            class="category-badge"
            style={`background: ${app.gradientFrom}20; border: 1px solid ${app.gradientFrom}40; color: ${app.accentColor};`}
          >
            {app.category}
          </span>
          <h1>{app.name}</h1>
          <p class="tagline" style={`color: ${app.accentColor};`}>{app.tagline}</p>
          <p class="description">{app.description}</p>
          <div class="hero-actions">
            <a
              href={`/${app.id}/privacy-policy/`}
              class="btn-cta"
              style={`background: ${app.gradientFrom};`}
            >
              Privacy Policy
            </a>
            <a href="/" class="btn-ghost">← All Apps</a>
          </div>
        </div>
        <div class="hero-phone" aria-hidden="true">
          <PhoneMockup gradient={app.screenGradient} label={app.category} />
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="features-section">
      <div class="section-inner">
        <h2 class="section-title">What It Does</h2>
        <ul class="features-list">
          {
            app.features.map((f) => (
              <li>
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  aria-hidden="true"
                  style={`color: ${app.gradientFrom};`}
                >
                  <path d="M20 6L9 17l-5-5" />
                </svg>
                {f}
              </li>
            ))
          }
        </ul>

        <h2 class="section-title mt">App Details</h2>
        <div class="details-grid">
          {app.details.map((d) => <div class="detail-pill">{d}</div>)}
        </div>
      </div>
    </section>

    <!-- PRIVACY CTA -->
    <section class="privacy-cta">
      <div class="section-inner">
        <div
          class="cta-card"
          style={`border-color: ${app.gradientFrom}30;`}
        >
          <div>
            <h3>Privacy Policy</h3>
            <p>Learn how {app.name} handles your data.</p>
          </div>
          <a
            href={`/${app.id}/privacy-policy/`}
            class="btn-cta"
            style={`background: ${app.gradientFrom};`}
          >
            Read Policy
          </a>
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  .app-hero {
    padding: 80px 0;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 56px;
    align-items: center;
    width: min(1100px, calc(100% - 32px));
    margin: 0 auto;
  }

  .hero-content {
    max-width: 560px;
  }

  .category-badge {
    display: inline-block;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin-bottom: 20px;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-text);
    margin-bottom: 10px;
  }

  .tagline {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 14px;
  }

  .description {
    font-size: 0.95rem;
    color: var(--color-muted);
    line-height: 1.75;
    max-width: 480px;
    margin-bottom: 28px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-cta {
    display: inline-flex;
    padding: 0.75rem 1.4rem;
    border-radius: 999px;
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    transition: filter 0.15s, transform 0.15s;
  }
  .btn-cta:hover {
    filter: brightness(1.15);
    transform: translateY(-1px);
  }

  .btn-ghost {
    display: inline-flex;
    padding: 0.75rem 1.4rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-ghost:hover {
    border-color: rgba(255, 255, 255, 0.2);
    color: var(--color-text);
  }

  .section-inner {
    width: min(1100px, calc(100% - 32px));
    margin: 0 auto;
    padding: 72px 0;
  }

  .section-title {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 24px;
  }

  .mt {
    margin-top: 48px;
  }

  .features-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .features-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.95rem;
    color: var(--color-muted);
    line-height: 1.6;
    padding: 14px 18px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }

  .features-list li svg {
    flex-shrink: 0;
    margin-top: 3px;
  }

  .details-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .detail-pill {
    padding: 0.55rem 1.1rem;
    border-radius: 999px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    font-size: 0.875rem;
    color: var(--color-muted);
    font-weight: 500;
  }

  .privacy-cta .section-inner {
    padding-top: 0;
  }

  .cta-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 28px 32px;
    background: var(--color-surface);
    border: 1px solid;
    border-radius: var(--radius-card);
  }

  .cta-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .cta-card p {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-phone {
      display: none;
    }
    .cta-card {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
