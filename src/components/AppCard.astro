---
import type { App } from '@/data/apps';

interface Props {
  app: App;
}

const { app } = Astro.props;
---

<article class="app-card">
  <div
    class="card-accent"
    style={`background: linear-gradient(135deg, ${app.gradientFrom}, ${app.gradientTo});`}
  >
    <span class="category">{app.category}</span>
  </div>
  <div class="card-body">
    <h3>{app.name}</h3>
    <p class="tagline">{app.tagline}</p>
    <ul>
      {app.features.slice(0, 3).map((f) => <li>{f}</li>)}
    </ul>
    <div class="card-actions">
      <a href={`/${app.id}/`} class="btn-primary">View App →</a>
      <a href={`/${app.id}/privacy-policy/`} class="btn-ghost">Privacy</a>
    </div>
  </div>
</article>

<style>
  .app-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
  }
  .app-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.45);
  }

  .card-accent {
    height: 96px;
    display: flex;
    align-items: flex-end;
    padding: 14px 24px;
    flex-shrink: 0;
  }

  .category {
    display: inline-block;
    padding: 0.28rem 0.7rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(8px);
    color: #fff;
    font-size: 0.77rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .card-body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  h3 {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--color-text);
    margin-bottom: 6px;
  }

  .tagline {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin-bottom: 16px;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0 0 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  li {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  li::before {
    content: '›';
    color: var(--color-teal);
    flex-shrink: 0;
    font-size: 1rem;
    line-height: 1;
  }

  .card-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .btn-primary {
    display: inline-flex;
    padding: 0.6rem 1.1rem;
    border-radius: 999px;
    background: var(--color-teal);
    color: #fff;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 700;
    transition: filter 0.15s, transform 0.15s;
  }
  .btn-primary:hover {
    filter: brightness(1.15);
    transform: translateY(-1px);
  }

  .btn-ghost {
    display: inline-flex;
    padding: 0.6rem 1.1rem;
    border-radius: 999px;
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-ghost:hover {
    border-color: rgba(255, 255, 255, 0.2);
    color: var(--color-text);
  }
</style>
