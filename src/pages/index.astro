---
import Base from '@/layouts/Base.astro';
import AppCard from '@/components/AppCard.astro';
import { apps } from '@/data/apps';
import { site } from '@/data/site';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.name,
  url: site.url,
  description: site.description,
};
---

<Base title={site.name} description={site.description} jsonLd={jsonLd}>
  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-content">
          <span class="eyebrow">Official Developer Website</span>
          <h1>Build.<br />Ship.<br /><em>Delight.</em></h1>
          <p class="hero-sub">
            Codeek Apps is the home of practical, privacy-focused mobile apps
            for everyday use.
          </p>
          <div class="hero-actions">
            <a href="#apps" class="btn-primary">Browse Apps</a>
            <a href="/privacy/" class="btn-ghost">Privacy Policies</a>
          </div>
        </div>

        <div class="hero-visual" aria-hidden="true">
          <div class="orb orb-1"></div>
          <div class="orb orb-2"></div>
          <div class="orb orb-3"></div>
          <div class="stat-stack">
            <div class="stat-card">
              <span class="stat-num">4</span>
              <span class="stat-label">Apps</span>
            </div>
            <div class="stat-card">
              <span class="stat-num">0</span>
              <span class="stat-label">Cloud accounts required</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- APPS GRID -->
    <section class="apps-section" id="apps" aria-labelledby="apps-heading">
      <div class="section-inner">
        <h2 id="apps-heading" class="section-heading">App Portfolio</h2>
        <div class="apps-grid">
          {apps.map((app) => <AppCard app={app} />)}
        </div>
      </div>
    </section>

    <!-- VERIFICATION -->
    <section class="verify-section" aria-label="Google Play verification">
      <div class="section-inner">
        <div class="verify-card">
          <div class="verify-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M9 12l2 2 4-4" />
              <circle cx="12" cy="12" r="10" />
            </svg>
          </div>
          <div>
            <h3>Google Play &amp; AdMob Verification</h3>
            <p>
              This website is the official developer website used in Google Play
              app listings. The{' '}
              <a href="/app-ads.txt">app-ads.txt</a> file is hosted at the root
              of this domain for AdMob verification.
            </p>
            <code class="url-chip">https://codeek-ai.github.io/</code>
          </div>
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 88px 0;
    border-bottom: 1px solid var(--color-border);
    background:
      radial-gradient(circle at 15% 50%, rgba(14, 138, 106, 0.14) 0%, transparent 52%),
      radial-gradient(circle at 85% 20%, rgba(90, 181, 255, 0.11) 0%, transparent 42%),
      radial-gradient(circle at 65% 85%, rgba(242, 159, 5, 0.09) 0%, transparent 38%);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    width: min(1200px, calc(100% - 32px));
    margin: 0 auto;
  }

  .hero-content {
    max-width: 540px;
  }

  .eyebrow {
    display: inline-block;
    padding: 0.38rem 0.9rem;
    border-radius: 999px;
    background: rgba(14, 138, 106, 0.14);
    border: 1px solid rgba(14, 138, 106, 0.3);
    color: var(--color-teal);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin-bottom: 24px;
  }

  h1 {
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-text);
    margin-bottom: 20px;
  }

  h1 em {
    font-style: normal;
    background: linear-gradient(135deg, #0e8a6a 0%, #5ab5ff 50%, #f29f05 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--color-muted);
    line-height: 1.75;
    max-width: 420px;
    margin-bottom: 32px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    padding: 0.75rem 1.5rem;
    border-radius: 999px;
    background: var(--color-teal);
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    transition: filter 0.15s, transform 0.15s;
  }
  .btn-primary:hover {
    filter: brightness(1.15);
    transform: translateY(-1px);
  }

  .btn-ghost {
    display: inline-flex;
    padding: 0.75rem 1.5rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-ghost:hover {
    border-color: rgba(255, 255, 255, 0.2);
    color: var(--color-text);
  }

  .hero-visual {
    position: relative;
    height: 340px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    pointer-events: none;
  }
  .orb-1 { width: 200px; height: 200px; background: rgba(14, 138, 106, 0.32); top: 5%; right: 5%; }
  .orb-2 { width: 150px; height: 150px; background: rgba(90, 181, 255, 0.26); bottom: 10%; left: 0; }
  .orb-3 { width: 110px; height: 110px; background: rgba(242, 159, 5, 0.22); top: 45%; right: 28%; }

  .stat-stack {
    display: flex;
    flex-direction: column;
    gap: 14px;
    z-index: 1;
  }

  .stat-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 20px 28px;
    min-width: 190px;
    backdrop-filter: blur(12px);
  }

  .stat-num {
    display: block;
    font-size: 2.4rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .stat-label {
    font-size: 0.83rem;
    color: var(--color-muted);
    font-weight: 500;
  }

  .section-inner {
    width: min(1200px, calc(100% - 32px));
    margin: 0 auto;
    padding: 72px 0;
  }

  .section-heading {
    font-size: clamp(1.5rem, 3vw, 2.4rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 32px;
  }

  .apps-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .verify-section .section-inner {
    padding-top: 0;
  }

  .verify-card {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding: 26px 28px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
  }

  .verify-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(14, 138, 106, 0.15);
    color: var(--color-teal);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .verify-card h3 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 6px;
  }

  .verify-card p {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.65;
    margin-bottom: 10px;
  }

  .verify-card a {
    color: var(--color-teal);
  }

  .url-chip {
    display: inline-block;
    padding: 0.28rem 0.65rem;
    border-radius: 7px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--color-border);
    font-family: ui-monospace, monospace;
    font-size: 0.8rem;
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
    .apps-grid { grid-template-columns: 1fr; }
    .verify-card { flex-direction: column; }
  }
</style>
